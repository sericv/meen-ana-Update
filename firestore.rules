rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    // Admin UID — only this account can write cards and categories.
    function isAdmin() {
      return signedIn() && request.auth.uid == 'GjIev1orTnNtoHh9UPnBr9UF9Yd2';
    }

    function roomData(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function inRoom(roomId) {
      return signedIn() && request.auth.uid in roomData(roomId).playerUids;
    }

    function hostAndCodeUnchanged() {
      return request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.code == resource.data.code;
    }

    // ── Users ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;

      match /friends/{friendId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write: if false;
      }

      match /friendInbox/{senderId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write: if false;
      }

      match /friendOutbox/{targetUid} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write: if false;
      }

      match /roomInvites/{inviteId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write: if false;
      }

      match /socialInbox/{id} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // ── Username uniqueness ledger ─────────────────────────────────
    match /usernameClaims/{claimId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // ── Categories ─────────────────────────────────────────────────
    // Public read — anyone can see categories.
    // Write: admin only (dashboard + migration script).
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Cards ──────────────────────────────────────────────────────
    // Public read — gameplay and dashboard can read all cards.
    // Write: admin only (dashboard + migration script).
    match /cards/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Matchmaking ────────────────────────────────────────────────
    match /matchmakingPool/{poolId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /matchmakingResults/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Room codes ─────────────────────────────────────────────────
    match /roomCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['roomId'])
        && exists(/databases/$(database)/documents/rooms/$(request.resource.data.roomId))
        && get(/databases/$(database)/documents/rooms/$(request.resource.data.roomId)).data.hostUid == request.auth.uid;
      allow update, delete: if signedIn()
        && exists(/databases/$(database)/documents/rooms/$(resource.data.roomId))
        && get(/databases/$(database)/documents/rooms/$(resource.data.roomId)).data.hostUid == request.auth.uid;
    }

    // ── Rooms ──────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read: if signedIn() && (
        request.auth.uid in resource.data.playerUids
        || resource.data.openJoin == true
        || (
          resource.data.status == 'lobby'
          && resource.data.playerUids is list
          && resource.data.playerUids.size() < 2
        )
      );
      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.auth.uid in request.resource.data.playerUids
        && request.resource.data.keys().hasAll([
          'code','hostUid','players','playerUids','status','categoryId','tutorial',
          'matchId','createdAt','lastActivityAt','cleanupAt','openJoin',
          'questionTimerSec','answerTimerSec'
        ]);
      allow update: if signedIn() && hostAndCodeUnchanged() && (
        inRoom(roomId)
        || (
          resource.data.status == 'lobby'
          && resource.data.playerUids is list
          && resource.data.playerUids.size() < 2
          && request.resource.data.playerUids is list
          && request.resource.data.playerUids.size() == resource.data.playerUids.size() + 1
          && !(request.auth.uid in resource.data.playerUids)
          && request.auth.uid in request.resource.data.playerUids
        )
      );
      allow delete: if signedIn() && resource.data.hostUid == request.auth.uid;
    }

    match /rooms/{roomId}/messages/{msgId} {
      allow read: if signedIn() && inRoom(roomId);
      allow create, update, delete: if false;
    }

    match /rooms/{roomId}/playerCards/{playerUid} {
      allow read: if signedIn() && request.auth.uid != playerUid && inRoom(roomId);
      allow write: if false;
    }

    match /rooms/{roomId}/presence/{uid} {
      allow read: if signedIn() && inRoom(roomId);
      allow write: if signedIn() && request.auth.uid == uid && inRoom(roomId);
    }

    match /rooms/{roomId}/typing/{uid} {
      allow read: if signedIn() && inRoom(roomId);
      allow write: if signedIn() && request.auth.uid == uid && inRoom(roomId);
    }

    match /rooms/{roomId}/serverRate/{uid} {
      allow read, write: if false;
    }

    // ── Matches ────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if signedIn() && (
        (resource.data.playerOrder is list && request.auth.uid in resource.data.playerOrder)
        || (
          resource.data.roomId is string
          && exists(/databases/$(database)/documents/rooms/$(resource.data.roomId))
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(resource.data.roomId)).data.playerUids
        )
      );
      allow write: if false;
    }
  }
}
